{
  "name": "automation-ui-dashboard",
  "version": "1.0.0",
  "description": "Smart Building Management System with BMS Dashboard",
  "main": "backend/src/app.js",
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run install:frontend && npm run install:backend && npm run build:frontend",
    "start": "cd backend && npm start",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "postinstall": "npm run build"
  },
  "keywords": [
    "bms",
    "building-management",
    "automation",
    "dashboard",
    "scada",
    "monitoring"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/karthigai-Pandi/Automation-UI-dash-board.git"
  },
  "homepage": "https://github.com/karthigai-Pandi/Automation-UI-dash-board#readme"
}